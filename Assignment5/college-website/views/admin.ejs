<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Prestige Admin | Student List</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root { --navy: #0d1b3e; --gold: #f59e0b; }
        .bg-navy { background-color: var(--navy); }
        .table-hover tbody tr:hover { background-color: rgba(245, 158, 11, 0.05); }
    </style>
</head>
<body class="bg-light">

    <div class="bg-navy text-white py-4 mb-4 shadow">
        <div class="container d-flex justify-content-between align-items-center">
            <h2 class="mb-0 fw-bold">Prestige <span class="text-warning">Admin</span></h2>
            <a href="/registration" class="btn btn-warning btn-sm fw-bold">Add New Student</a>
        </div>
    </div>

    <div class="container">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="px-4 py-3">Student Name</th>
                            <th>Contact</th>
                            <th>Applied For</th>
                            <th>Location</th>
                            <th class="text-center">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% students.forEach(student => { %>
                        <tr>
                            <td class="px-4">
                                <div class="fw-bold text-navy"><%= student.firstName %> <%= student.lastName %></div>
                                <small class="text-muted">ID: <%= student._id.toString().slice(-6) %></small>
                            </td>
                            <td>
                                <div class="small"><i data-lucide="mail" class="me-1" size="14"></i><%= student.email %></div>
                                <div class="small"><i data-lucide="phone" class="me-1" size="14"></i><%= student.phone %></div>
                            </td>
                            <td>
                                <span class="badge rounded-pill bg-primary bg-opacity-10 text-primary"><%= student.course %></span>
                                <div class="small mt-1 text-muted">Score: <%= student.percentage %>%</div>
                            </td>
                            <td><%= student.city %></td>
                            <td class="text-center">
                                <form action="/delete/<%= student._id %>" method="POST">
                                    <button class="btn text-danger p-0 border-0"><i data-lucide="trash-2" size="18"></i></button>
                                </form>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>lucide.createIcons();</script>
</body>
</html>