<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Courses | Prestige Institute</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root { --navy-main: #1a237e; --gold-main: #f59e0b; }
        body { font-family: 'Montserrat', sans-serif; }
        .hero-gradient { background: linear-gradient(135deg, #1a237e 0%, #0d1b3e 100%); }
        .course-card { transition: all 0.3s ease; }
        .course-card:hover { transform: translateY(-10px); box-shadow: 0 1rem 3rem rgba(0,0,0,0.1) !important; }
        .course-icon-wrapper { width: 56px; height: 56px; border-radius: 12px; display: flex; align-items: center; justify-content: center; }
        .filter-btn.active { background-color: var(--navy-main) !important; color: white !important; }
        .footer-main { background-color: #0d1b3e; color: white; }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark hero-gradient sticky-top">
        <div class="container">
            <a class="navbar-brand fw-bold" href="/">PRESTIGE INSTITUTE</a>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link active" href="/courses">Courses</a></li>
                    <li class="nav-item"><a class="btn btn-warning ms-lg-3" href="/registration">Apply Now</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <section class="py-5 hero-gradient text-white text-center">
            <div class="container py-5">
                <h1 class="display-4 fw-bold">Explore Our Courses</h1>
                <p class="lead opacity-75">Industry-aligned engineering programs.</p>
            </div>
        </section>

        <section class="bg-white border-bottom sticky-top shadow-sm" style="top:56px;">
            <div class="container py-3">
                <div class="d-flex gap-2 overflow-auto" id="filterGroup">
                    <% departments.forEach(dept => { %>
                        <button class="btn btn-light btn-sm filter-btn <%= dept.id === 'all' ? 'active' : '' %>" 
                                data-filter="<%= dept.id %>" onclick="filterByDept('<%= dept.id %>')">
                            <%= dept.name %>
                        </button>
                    <% }) %>
                </div>
            </div>
        </section>

        <section class="py-5 bg-light">
            <div class="container">
                <div class="row g-4" id="courseGrid">
                    <% courses.forEach(course => { %>
                        <div class="col-md-6 col-lg-4 course-item" data-category="<%= course.department %>">
                            <div class="card h-100 course-card p-4 rounded-4 shadow-sm" style="background-color: <%= course.bgLight %>;">
                                <div class="d-flex justify-content-between mb-4">
                                    <div class="course-icon-wrapper <%= course.color %> text-white">
                                        <i data-lucide="<%= course.icon %>"></i>
                                    </div>
                                    <span class="badge bg-white text-muted border"><%= course.shortName %></span>
                                </div>
                                <h4 class="fw-bold"><%= course.name %></h4>
                                <p class="small text-muted mb-4"><%= course.description %></p>
                                <div class="mt-auto">
                                    <a href="/registration?course=<%= course.shortName %>" class="btn btn-primary w-100 fw-bold">Apply Now</a>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </section>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        lucide.createIcons();
        function filterByDept(deptId) {
            // Update UI buttons
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            event.target.classList.add('active');
            
            // Filter logic
            document.querySelectorAll('.course-item').forEach(item => {
                if (deptId === 'all' || item.dataset.category === deptId) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>