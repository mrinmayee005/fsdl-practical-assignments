<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Faculty | Prestige Institute of Engineering & Technology</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            --navy-main: #1a237e;
            --gold-main: #f59e0b;
            --gold-hover: #d97706;
        }

        body { font-family: 'Montserrat', sans-serif; background-color: #f8f9fa; }

        /* --- Navbar Styles (Matches Previous) --- */
        .navbar { transition: all 0.5s ease; padding: 20px 0; }
        .navbar.scrolled { 
            background: white !important; 
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1); 
            padding: 10px 0; 
        }
        .nav-link { 
            color: rgba(255,255,255,0.9) !important; 
            font-size: 0.875rem; 
            font-weight: 500; 
            padding: 8px 16px !important; 
        }
        .navbar.scrolled .nav-link { color: #374151 !important; }
        .navbar.scrolled .navbar-brand h1 { color: var(--navy-main) !important; }
        .navbar.scrolled .logo-box { background: var(--navy-main) !important; }
        .logo-box { background: rgba(255,255,255,0.2); transition: all 0.3s ease; }
        
        .btn-apply {
            background: linear-gradient(to right, var(--gold-main), var(--gold-hover));
            color: white !important; border: none; padding: 10px 24px !important;
            border-radius: 8px; font-weight: 600; transition: all 0.3s ease;
        }

        /* --- Hero Section --- */
        .hero-gradient { background: linear-gradient(135deg, #1a237e 0%, #0d1b3e 100%); }
        .sticky-filter { 
            top: 70px; 
            z-index: 1020; 
            background: rgba(255,255,255,0.98); 
            backdrop-filter: blur(10px);
        }

        /* --- Faculty Cards --- */
        .faculty-card {
            border: none;
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.4s ease;
            background: white;
        }
        .faculty-card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.1) !important;
        }
        .faculty-img-wrapper {
            height: 280px;
            overflow: hidden;
            position: relative;
        }
        .faculty-img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }
        .faculty-card:hover .faculty-img {
            transform: scale(1.1);
        }
        .social-overlay {
            position: absolute;
            bottom: 15px;
            right: 15px;
            display: flex;
            gap: 8px;
            opacity: 0;
            transition: 0.3s ease;
        }
        .faculty-card:hover .social-overlay { opacity: 1; }
        .social-icon {
            width: 35px; height: 35px; background: white;
            border-radius: 8px; display: flex; align-items: center; justify-content: center;
            color: var(--navy-main); text-decoration: none; transition: 0.3s;
        }
        .social-icon:hover { background: var(--navy-main); color: white; }

        .dept-badge {
            position: absolute; top: 15px; left: 15px;
            background: var(--navy-main); color: white;
            padding: 5px 15px; border-radius: 50px; font-size: 0.7rem; font-weight: 600;
        }

        .filter-btn { border-radius: 8px; transition: 0.3s; border: 1px solid #eee; }
        .filter-btn.active { background: var(--navy-main) !important; color: white !important; }

        /* --- Footer (Matches Previous) --- */
        .footer-main { background-color: #0d1b3e; color: white; }
        .footer-newsletter { background: linear-gradient(to right, #1a237e, #283593); }
        .footer-link { color: rgba(255,255,255,0.7); text-decoration: none; transition: 0.3s; display: flex; align-items: center; gap: 8px; font-size: 0.9rem; }
        .footer-link:hover { color: var(--gold-main); transform: translateX(5px); }
        .footer-heading-line { width: 32px; height: 4px; background-color: var(--gold-main); border-radius: 2px; display: inline-block; }
    </style>
</head>
<body>

    <nav class="navbar navbar-expand-lg fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-3" href="/">
                <div class="logo-box p-2 rounded-3">
                    <i data-lucide="graduation-cap" class="text-white" style="width: 32px; height: 32px;"></i>
                </div>
                <div>
                    <h1 class="h5 fw-bold mb-0 text-white">Prestige Institute</h1>
                    <p class="small mb-0 text-white-50 tracking-wider" style="font-size: 10px;">OF ENGINEERING & TECHNOLOGY</p>
                </div>
            </a>
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i data-lucide="menu" class="text-white"></i>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center gap-1">
                    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="/about">About Us</a></li>
                    <li class="nav-item"><a class="nav-link" href="/courses">Courses</a></li>
                    <li class="nav-item"><a class="nav-link" href="/admissions">Admissions</a></li>
                    <li class="nav-item"><a class="nav-link" href="/faculty">Faculty</a></li>
                    <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
                    <li class="nav-item ms-lg-3"><a class="btn btn-apply" href="/registration">Apply Now</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        <section class="py-5 hero-gradient text-white pt-5">
            <div class="container py-5 mt-5 text-center">
                <span class="badge rounded-pill bg-white bg-opacity-25 text-warning px-3 py-2 mb-4">Our Academic Pillars</span>
                <h1 class="display-4 fw-bold mb-3">Meet Our Distinguished Faculty</h1>
                <p class="lead opacity-75 mx-auto" style="max-width: 700px;">
                    Learn from industry experts and renowned academicians dedicated to shaping the next generation of global engineers.
                </p>
            </div>
        </section>

        <section class="bg-white border-bottom sticky-top sticky-filter shadow-sm">
            <div class="container py-3">
                <div class="row g-3 align-items-center">
                    <div class="col-md-4">
                        <div class="input-group border rounded-3">
                            <span class="input-group-text bg-transparent border-0 text-muted">
                                <i data-lucide="search" size="18"></i>
                            </span>
                            <input type="text" id="facultySearch" class="form-control border-0 shadow-none" placeholder="Search by name or specialization...">
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="d-flex gap-2 overflow-auto pb-1" id="filterGroup">
                            <button class="btn btn-light btn-sm text-nowrap filter-btn active" data-filter="all">All Departments</button>
                            <button class="btn btn-light btn-sm text-nowrap filter-btn" data-filter="cse">Computer Science</button>
                            <button class="btn btn-light btn-sm text-nowrap filter-btn" data-filter="me">Mechanical</button>
                            <button class="btn btn-light btn-sm text-nowrap filter-btn" data-filter="ee">Electrical</button>
                            <button class="btn btn-light btn-sm text-nowrap filter-btn" data-filter="ce">Civil</button>
                            <button class="btn btn-light btn-sm text-nowrap filter-btn" data-filter="ece">Electronics</button>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section class="py-5">
            <div class="container">
                <div class="row g-4" id="facultyGrid">
                    <% facultyData.forEach(faculty => { %>
                        <div class="col-sm-6 col-lg-4 col-xl-3 faculty-item" data-category="<%= faculty.department %>">
                            <div class="card faculty-card shadow-sm h-100">
                                <div class="faculty-img-wrapper">
                                    <img src="<%= faculty.photo %>" class="faculty-img" alt="<%= faculty.name %>">
                                    <div class="dept-badge">
                                        <%= departments.find(d => d.id === faculty.department)?.name %>
                                    </div>
                                    <div class="social-overlay">
                                        <a href="mailto:<%= faculty.email %>" class="social-icon"><i data-lucide="mail" size="16"></i></a>
                                        <a href="#" class="social-icon"><i data-lucide="linkedin" size="16"></i></a>
                                    </div>
                                </div>
                                <div class="card-body p-4">
                                    <h5 class="fw-bold mb-1 text-dark"><%= faculty.name %></h5>
                                    <p class="text-primary small fw-semibold mb-3"><%= faculty.designation %></p>
                                    
                                    <div class="space-y-2">
                                        <div class="d-flex align-items-start gap-2 mb-2">
                                            <i data-lucide="graduation-cap" size="14" class="text-muted mt-1"></i>
                                            <span class="small text-muted"><%= faculty.qualification %></span>
                                        </div>
                                        <div class="d-flex align-items-start gap-2 mb-2">
                                            <i data-lucide="book-open" size="14" class="text-muted mt-1"></i>
                                            <span class="small text-muted"><%= faculty.specialization %></span>
                                        </div>
                                        <div class="d-flex align-items-start gap-2">
                                            <i data-lucide="award" size="14" class="text-muted mt-1"></i>
                                            <span class="small text-muted"><%= faculty.experience %> Experience</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    <% }) %>
                </div>

                <div id="noResults" class="text-center py-5 d-none">
                    <i data-lucide="user-x" size="48" class="text-muted mb-3"></i>
                    <h3 class="fw-bold">No Faculty Found</h3>
                    <p class="text-muted">Try adjusting your filters or search keywords.</p>
                </div>
            </div>
        </section>

        <section class="py-5 bg-white border-top">
            <div class="container">
                <div class="row g-4 text-center">
                    <div class="col-6 col-md-3">
                        <div class="p-4 bg-light rounded-4">
                            <h2 class="fw-bold text-dark mb-1">500+</h2>
                            <p class="text-muted mb-0">Faculty Members</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-4 bg-light rounded-4">
                            <h2 class="fw-bold text-dark mb-1">150+</h2>
                            <p class="text-muted mb-0">Ph.D. Holders</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-4 bg-light rounded-4">
                            <h2 class="fw-bold text-dark mb-1">50+</h2>
                            <p class="text-muted mb-0">Industry Experts</p>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="p-4 bg-light rounded-4">
                            <h2 class="fw-bold text-dark mb-1">15:1</h2>
                            <p class="text-muted mb-0">Student Ratio</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <footer class="footer-main">
        <div class="footer-newsletter py-5">
            <div class="container">
                <div class="row align-items-center justify-content-between g-4">
                    <div class="col-md-6">
                        <h3 class="fw-bold mb-2 text-white">Subscribe to Our Newsletter</h3>
                        <p class="text-white-50 mb-0">Get updates on research and academic excellence.</p>
                    </div>
                    <div class="col-md-5">
                        <div class="input-group">
                            <input type="email" class="form-control bg-white bg-opacity-10 border-white-20 text-white p-3 shadow-none" placeholder="Enter your email">
                            <button class="btn btn-warning px-4"><i data-lucide="send"></i></button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container py-5">
            <div class="row g-5">
                <div class="col-lg-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="p-2 bg-white bg-opacity-10 rounded-3">
                            <i data-lucide="graduation-cap" class="text-warning"></i>
                        </div>
                        <div>
                            <h4 class="h5 fw-bold mb-0 text-white">Prestige Institute</h4>
                            <p class="small text-white-50 mb-0">ENGINEERING & TECH</p>
                        </div>
                    </div>
                    <p class="text-white-50 small mb-4">Building a legacy of academic excellence and research-driven innovation.</p>
                    <div class="d-flex gap-2">
                        <a href="#" class="social-icon bg-white bg-opacity-10 text-white"><i data-lucide="facebook" size="18"></i></a>
                        <a href="#" class="social-icon bg-white bg-opacity-10 text-white"><i data-lucide="linkedin" size="18"></i></a>
                        <a href="#" class="social-icon bg-white bg-opacity-10 text-white"><i data-lucide="twitter" size="18"></i></a>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-4 text-white"><span class="footer-heading-line me-2"></span>Useful Links</h5>
                    <div class="row">
                        <div class="col-6">
                            <ul class="list-unstyled">
                                <li class="mb-2"><a href="/faculty" class="footer-link">Our Faculty</a></li>
                                <li class="mb-2"><a href="/courses" class="footer-link">Programs</a></li>
                                <li class="mb-2"><a href="/admissions" class="footer-link">Admissions</a></li>
                            </ul>
                        </div>
                        <div class="col-6">
                            <ul class="list-unstyled">
                                <li class="mb-2"><a href="/research" class="footer-link">Research</a></li>
                                <li class="mb-2"><a href="/contact" class="footer-link">Contact</a></li>
                                <li class="mb-2"><a href="/about" class="footer-link">About Us</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h5 class="fw-bold mb-4 text-white"><span class="footer-heading-line me-2"></span>Contact Us</h5>
                    <ul class="list-unstyled text-white-50 small">
                        <li class="d-flex gap-3 mb-3"><i data-lucide="map-pin" class="text-warning"></i> 123 University Ave, Indore, MP</li>
                        <li class="d-flex gap-3 mb-3"><i data-lucide="phone" class="text-warning"></i> +1 (555) 123-4567</li>
                        <li class="d-flex gap-3 mb-3"><i data-lucide="mail" class="text-warning"></i> info@prestige.edu</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="text-center py-4 border-top border-white border-opacity-10">
            <p class="small text-white-50 mb-0">© 2026 Prestige Institute of Engineering & Technology. All rights reserved.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Initialize Icons
        lucide.createIcons();

        // Navbar Scroll Effect
        window.addEventListener('scroll', function() {
            const nav = document.getElementById('mainNav');
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });

        // Filter and Search Logic
        const searchInput = document.getElementById('facultySearch');
        const filterBtns = document.querySelectorAll('.filter-btn');
        const facultyItems = document.querySelectorAll('.faculty-item');
        const noResults = document.getElementById('noResults');

        function filterFaculty() {
            const query = searchInput.value.toLowerCase();
            const activeFilter = document.querySelector('.filter-btn.active').dataset.filter;
            let visibleCount = 0;

            facultyItems.forEach(item => {
                const name = item.querySelector('h5').textContent.toLowerCase();
                const spec = item.querySelector('.faculty-card').textContent.toLowerCase();
                const category = item.dataset.category;
                
                const matchesSearch = name.includes(query) || spec.includes(query);
                const matchesFilter = activeFilter === 'all' || category === activeFilter;

                if (matchesSearch && matchesFilter) {
                    item.classList.remove('d-none');
                    visibleCount++;
                } else {
                    item.classList.add('d-none');
                }
            });

            noResults.classList.toggle('d-none', visibleCount > 0);
        }

        searchInput.addEventListener('input', filterFaculty);
        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');
                filterFaculty();
            });
        });
    </script>
</body>
</html>