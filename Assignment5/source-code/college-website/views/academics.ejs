<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Prestige Institute of Engineering & Technology</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
      
        .navbar {
            transition: all 0.5s ease;
            padding: 20px 0;
        }
        .navbar.scrolled {
            background: white !important;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            padding: 10px 0;
        }
        .nav-link {
            color: rgba(255,255,255,0.9) !important;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 8px 16px !important;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .navbar.scrolled .nav-link {
            color: #374151 !important; /* Gray-700 */
        }
        .nav-link:hover {
            background: rgba(255,255,255,0.2);
        }
        .navbar.scrolled .nav-link:hover {
            background: #f3f4f6;
        }
        .navbar.scrolled .navbar-brand h1 { color: var(--navy-main) !important; }
        .navbar.scrolled .navbar-brand p { color: #6b7280 !important; }
        .navbar.scrolled .logo-box { background: var(--navy-main) !important; }

        .btn-apply {
            background: linear-gradient(to right, var(--gold-main), var(--gold-hover));
            color: white !important;
            border: none;
            padding: 10px 24px !important;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .btn-apply:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(245, 158, 11, 0.3);
        }
        .footer-main { background-color: #0d1b3e; color: white; }
.footer-newsletter { background: linear-gradient(to right, #1a237e, #283593); }

.footer-link {
    color: rgba(255,255,255,0.7);
    text-decoration: none;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
}

.footer-link:hover {
    color: var(--gold-main);
    transform: translateX(5px);
}

.social-btn {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255,255,255,0.1);
    border-radius: 8px;
    color: white;
    transition: all 0.3s ease;
}

.social-btn:hover {
    background: var(--gold-main);
    color: white;
    transform: translateY(-3px);
}

.footer-heading-line {
    width: 32px;
    height: 4px;
    background-color: var(--gold-main);
    border-radius: 2px;
    display: inline-block;
}
    </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-3" href="#">
                <div class="logo-box p-2 rounded-3 bg-white-20 transition-all">
                    <i data-lucide="graduation-cap" class="text-white" style="width: 32px; height: 32px;"></i>
                </div>
                <div>
                    <h1 class="h5 fw-bold mb-0 text-white transition-all">Prestige Institute</h1>
                    <p class="small mb-0 text-white-50 tracking-wider transition-all" style="font-size: 10px;">OF ENGINEERING & TECHNOLOGY</p>
                </div>
            </a>
            
            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <i data-lucide="menu" class="text-white"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarNav">
              <ul class="navbar-nav ms-auto align-items-center gap-1">
    <li class="nav-item"><a class="nav-link" href="/">Home</a></li>
    <li class="nav-item"><a class="nav-link" href="/about">About Us</a></li>
    <li class="nav-item"><a class="nav-link" href="/courses">Courses</a></li>
    <li class="nav-item"><a class="nav-link" href="/admissions">Admissions</a></li>
    <li class="nav-item"><a class="nav-link" href="/faculty">Faculty</a></li>
    <li class="nav-item"><a class="nav-link" href="/contact">Contact</a></li>
    <li class="nav-item ms-lg-3">
        <a class="btn btn-apply" href="/registration">Apply Now</a>
    </li>
</ul>
            </div>
        </div>
    </nav>
   
    
<footer class="footer-main mt-5">
    <div class="footer-newsletter py-5">
        <div class="container">
            <div class="row align-items-center justify-content-between g-4">
                <div class="col-md-6">
                    <h3 class="fw-bold mb-2">Subscribe to Our Newsletter</h3>
                    <p class="text-white-50 mb-0">Stay updated with latest news and announcements</p>
                </div>
                <div class="col-md-5">
                    <div class="input-group">
                        <input type="email" class="form-control bg-white-20 border-white-20 text-white p-3" placeholder="Enter your email" style="background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.2);">
                        <button class="btn btn-warning px-4"><i data-lucide="send"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="container py-5">
        <div class="row g-5">
            <div class="col-lg-3 col-md-6">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="p-2 bg-white-20 rounded-3">
                        <i data-lucide="graduation-cap" class="text-gold" style="width: 32px; height: 32px;"></i>
                    </div>
                    <div>
                        <h4 class="h5 fw-bold mb-0">Prestige Institute</h4>
                        <p class="small text-white-50 mb-0">OF ENGINEERING & TECHNOLOGY</p>
                    </div>
                </div>
                <p class="text-white-50 small mb-4">Empowering minds, shaping futures. A premier institution committed to excellence in engineering education since 1985.</p>
                <div class="d-flex gap-2">
                    <a href="#" class="social-btn"><i data-lucide="facebook" size="18"></i></a>
                    <a href="#" class="social-btn"><i data-lucide="twitter" size="18"></i></a>
                    <a href="#" class="social-btn"><i data-lucide="instagram" size="18"></i></a>
                    <a href="#" class="social-btn"><i data-lucide="linkedin" size="18"></i></a>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                    <span class="footer-heading-line"></span> Quick Links
                </h5>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="/about" class="footer-link">About Us</a></li>
                    <li class="mb-2"><a href="/courses" class="footer-link">Courses</a></li>
                    <li class="mb-2"><a href="/admissions" class="footer-link">Admissions</a></li>
                    <li class="mb-2"><a href="/faculty" class="footer-link">Faculty</a></li>
                    <li class="mb-2"><a href="/contact" class="footer-link">Contact Us</a></li>
                </ul>
            </div>

            <div class="col-lg-3 col-md-6">
                <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                    <span class="footer-heading-line"></span> Popular Courses
                </h5>
                <ul class="list-unstyled">
                    <li class="mb-2"><a href="/courses" class="footer-link">Computer Science</a></li>
                    <li class="mb-2"><a href="/courses" class="footer-link">Mechanical Engineering</a></li>
                    <li class="mb-2"><a href="/courses" class="footer-link">Electrical Engineering</a></li>
                    <li class="mb-2"><a href="/courses" class="footer-link">Civil Engineering</a></li>
                </ul>
            </div>

            <div class="col-lg-3 col-md-6">
                <h5 class="fw-bold mb-4 d-flex align-items-center gap-2">
                    <span class="footer-heading-line"></span> Contact Us
                </h5>
                <ul class="list-unstyled text-white-50 small">
                    <li class="d-flex gap-3 mb-3">
                        <i data-lucide="map-pin" class="text-gold flex-shrink-0"></i>
                        <span>123 University Avenue, Tech City, State 456789</span>
                    </li>
                    <li class="d-flex gap-3 mb-3">
                        <i data-lucide="phone" class="text-gold flex-shrink-0"></i>
                        <span>+1 (555) 123-4567</span>
                    </li>
                    <li class="d-flex gap-3 mb-3">
                        <i data-lucide="mail" class="text-gold flex-shrink-0"></i>
                        <span>info@prestigetech.edu</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>

    <div class="border-top border-white-20 py-4 mt-4">
        <div class="container text-center text-md-start">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <p class="small text-white-50 mb-0">© 2024 Prestige Institute of Engineering & Technology. All rights reserved.</p>
                </div>
                <div class="col-md-6 text-md-end mt-3 mt-md-0">
                    <a href="#" class="small text-white-50 text-decoration-none me-3 hover-gold">Privacy Policy</a>
                    <a href="#" class="small text-white-50 text-decoration-none">Terms of Service</a>
                </div>
            </div>
        </div>
    </div>
</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Initialize Lucide Icons
        lucide.createIcons();

        // Refresh icons on carousel slide (if needed)
        const myCarousel = document.getElementById('heroCarousel');
        myCarousel.addEventListener('slid.bs.carousel', () => {
            lucide.createIcons();
        });
        window.addEventListener('scroll', function() {
            const nav = document.getElementById('mainNav');
            if (window.scrollY > 50) {
                nav.classList.add('scrolled');
            } else {
                nav.classList.remove('scrolled');
            }
        });
    </script>
</body>
</html>