    <style>
        :root {
            --navy-main: #1a237e;
            --navy-dark: #121858;
            --gold-main: #ffb300;
            --light-blue: #eff6ff;
            --glass-white: rgba(255, 255, 255, 0.1);
        }

        body { 
            font-family: 'Montserrat', sans-serif; 
            margin: 0; 
            overflow-x: hidden;
            color: #333;
        }

        /* --- Utility Classes --- */
        .bg-navy { background-color: var(--navy-main); }
        .text-navy { color: var(--navy-main); }
        .bg-navy-light { background-color: rgba(26, 35, 126, 0.1); }
        .bg-gold { background-color: var(--gold-main); color: #fff; }
        .text-gold { color: var(--gold-main); }
        .bg-white-20 { background-color: var(--glass-white); }
        .backdrop-blur { backdrop-filter: blur(10px); background: var(--glass-white); }
        .bg-dark-gradient { background: linear-gradient(to top, rgba(0,0,0,0.9), transparent); }

        /* --- Hero Carousel --- */
        .vh-100 { height: 100vh; }
        .hero-overlay {
            position: absolute; inset: 0;
            background: linear-gradient(to right, rgba(26, 35, 126, 0.85), rgba(26, 35, 126, 0.4), transparent);
            z-index: 2;
        }
        .slide-bg {
            position: absolute; inset: 0;
            background-size: cover; background-position: center;
            transition: transform 6s ease; z-index: 1;
        }
        .carousel-item.active .slide-bg { transform: scale(1.1); }
        .max-w-700 { max-width: 700px; }

        /* --- About Section Images --- */
        .img-stack img { transition: transform 0.3s ease; }
        .img-stack img:hover { transform: scale(1.02); }

        /* --- Course Cards --- */
        .course-card { 
            transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); 
            border: 1px solid #eee !important;
        }
        .course-card:hover { 
            transform: translateY(-12px); 
            border-color: var(--navy-main) !important; 
            box-shadow: 0 20px 40px rgba(0,0,0,0.1); 
        }
        .icon-box {
            width: 60px; height: 60px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 15px; font-size: 24px;
        }
        .bg-gradient-blue { background: linear-gradient(135deg, #3b82f6, #4f46e5); }
        .bg-gradient-orange { background: linear-gradient(135deg, #f59e0b, #d97706); }
        .bg-gradient-green { background: linear-gradient(135deg, #10b981, #059669); }

        /* --- News Ticker --- */
        .ticker-wrapper { overflow: hidden; white-space: nowrap; }
        .ticker-text {
            display: inline-block;
            padding-left: 100%;
            animation: marquee 25s linear infinite;
        }
        @keyframes marquee {
            0% { transform: translateX(0); }
            100% { transform: translateX(-100%); }
        }

        /* --- Stats Glass Cards --- */
        .stat-card-glass {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
            padding: 25px;
            text-align: center;
        }

        /* --- Animations --- */
        .pulse-dot-amber {
            width: 10px; height: 10px;
            background: var(--gold-main); border-radius: 50%;
            display: inline-block; animation: pulse 1.8s infinite;
        }
        @keyframes pulse {
            0% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.6); opacity: 0.4; }
            100% { transform: scale(1); opacity: 1; }
        }

        .animate-up { opacity: 0; animation: fadeInUp 0.8s forwards; }
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(30px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .navbar {
            transition: all 0.5s ease;
            padding: 20px 0;
        }
        .navbar.scrolled {
            background: white !important;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            padding: 10px 0;
        }
        .nav-link {
            color: rgba(255,255,255,0.9) !important;
            font-size: 0.875rem;
            font-weight: 500;
            padding: 8px 16px !important;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        .navbar.scrolled .nav-link {
            color: #374151 !important; /* Gray-700 */
        }
        .nav-link:hover {
            background: rgba(255,255,255,0.2);
        }
        .navbar.scrolled .nav-link:hover {
            background: #f3f4f6;
        }
        .navbar.scrolled .navbar-brand h1 { color: var(--navy-main) !important; }
        .navbar.scrolled .navbar-brand p { color: #6b7280 !important; }
        .navbar.scrolled .logo-box { background: var(--navy-main) !important; }

        .btn-apply {
            background: linear-gradient(to right, var(--gold-main), var(--gold-hover));
            color: white !important;
            border: none;
            padding: 10px 24px !important;
            border-radius: 8px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        .btn-apply:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px -3px rgba(245, 158, 11, 0.3);
        }
