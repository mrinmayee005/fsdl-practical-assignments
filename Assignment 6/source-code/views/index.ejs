<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VOGUE ETHNIC</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        :root { --accent: #ff3e6c; --dark: #0f0f0f; }
        body { font-family: 'Plus Jakarta Sans', sans-serif; background: #fdfdfd; }
        .product-card { border: none; transition: 0.3s; margin-bottom: 30px; }
        .img-box { border-radius: 20px; overflow: hidden; height: 350px; background: #eee; position: relative; }
        .img-box img { width: 100%; height: 100%; object-fit: cover; }
        .cart-sidebar { position: fixed; right: -400px; top: 0; width: 350px; height: 100vh; background: white; z-index: 2050; transition: 0.4s; box-shadow: -10px 0 30px rgba(0,0,0,0.1); }
        .cart-sidebar.open { right: 0; }
        .btn-luxe { background: var(--dark); color: white; border-radius: 50px; border: none; padding: 10px; width: 100%; font-weight: bold; }
        #checkoutAlert { display: none; position: fixed; top: 20px; left: 50%; transform: translateX(-50%); z-index: 3000; }
    </style>
</head>
<body>

    <div id="checkoutAlert" class="alert alert-success shadow-lg">✅ Order booked!</div>

    <nav class="navbar border-bottom bg-white sticky-top py-3">
        <div class="container">
            <a class="navbar-brand fw-bold fs-3" href="#">VOGUE ETHNIC.</a>
            <div id="cartTrigger" style="cursor:pointer; position:relative;">
                <i data-lucide="shopping-bag"></i>
                <span id="cartCount" class="badge bg-danger rounded-pill position-absolute top-0 start-100 translate-middle">0</span>
            </div>
        </div>
    </nav>

    <div class="container mt-5">
        <div class="row" id="mainGrid"></div>
    </div>

    <div class="cart-sidebar" id="cartSidebar">
        <div class="p-4 border-bottom d-flex justify-content-between">
            <h4 class="mb-0">Your Bag</h4>
            <button class="btn-close" onclick="toggleCart(false)"></button>
        </div>
        <div class="p-4 flex-grow-1" id="cartList"></div>
        <div class="p-4 border-top">
            <h5 class="d-flex justify-content-between">Total: <span id="totalPrice">$0</span></h5>
            <button class="btn-luxe mt-3" onclick="handleCheckout()">Complete Order</button>
        </div>
    </div>

    <script>
        const products = <%- JSON.stringify(products) %>;
        let cart = [];

        function render() {
            document.getElementById('mainGrid').innerHTML = products.map(p => `
                <div class="col-md-4">
                    <div class="product-card">
                        <div class="img-box"><img src="${p.img}"></div>
                        <div class="mt-3 d-flex justify-content-between">
                            <b>${p.name}</b> <span>$${p.price}</span>
                        </div>
                        <button class="btn-luxe mt-2" onclick="addToCart('${p._id}')">Add to Bag</button>
                    </div>
                </div>
            `).join('');
            lucide.createIcons();
        }

        function addToCart(id) {
            const item = products.find(p => p._id === id);
            cart.push(item);
            updateUI();
            toggleCart(true);
        }

        function updateUI() {
            document.getElementById('cartCount').innerText = cart.length;
            const total = cart.reduce((sum, p) => sum + p.price, 0);
            document.getElementById('totalPrice').innerText = `$${total}`;
            document.getElementById('cartList').innerHTML = cart.map((p, i) => `
                <div class="d-flex justify-content-between mb-2">
                    <span>${p.name}</span> <b>$${p.price}</b>
                </div>
            `).join('');
        }

        // SENDING DATA TO MONGODB
        async function handleCheckout() {
            if (cart.length === 0) return alert("Bag is empty");

            const orderData = {
                items: cart,
                totalPrice: cart.reduce((sum, p) => sum + p.price, 0)
            };

            try {
                const response = await fetch('/place-order', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(orderData)
                });

                if (response.ok) {
                    const alertBox = document.getElementById('checkoutAlert');
                    alertBox.style.display = 'block';
                    cart = [];
                    updateUI();
                    toggleCart(false);
                    setTimeout(() => alertBox.style.display = 'none', 3000);
                }
            } catch (err) {
                alert("Error connecting to server");
            }
        }

        function toggleCart(s) { document.getElementById('cartSidebar').classList.toggle('open', s); }
        document.getElementById('cartTrigger').onclick = () => toggleCart(true);
        render();
    </script>
</body>
</html>